{
  "name": "mcp-dev-console",
  "private": true,
  "description": "Monorepo for MCP Dev Console — a Postman-style tool explorer for Model Context Protocol servers",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "lint": "tsc --noEmit --project apps/web/tsconfig.json",
    "format": "prettier --write '**/*.{ts,tsx,json,md,css}'",
    "format:check": "prettier --check '**/*.{ts,tsx,json,md,css}'"
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "typescript": "^5.0.0"
  },
  "engines": { "node": ">=20" }
}
